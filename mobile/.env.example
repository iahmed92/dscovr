# Expo bakes EXPO_PUBLIC_* vars into the client bundle at build time — these
# are not secret, they're the same anon/public key + URL used by preview.html,
# gated by Supabase's read-only RLS policies rather than by being hidden.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
